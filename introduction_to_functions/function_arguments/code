#include <iostream>

int withdraw(int current_balance, int withdrawal_amount) 
{
    if (current_balance >= withdrawal_amount)
        return current_balance - withdrawal_amount;
    return current_balance;
}

int main() 
{
    int balance = 200, amount = 500;
    balance = withdraw(balance, amount);
    std::cout << "Balance after withdraw is: $" << balance << std::endl;

    return 0;
}